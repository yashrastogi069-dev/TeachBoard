{
  "name": "Praxis - Supabase keep-alive",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
            }
          ]
        }
      },
      "id": "schedule-keepalive",
      "name": "Every day 08:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3000/api/cron/keepalive",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-cron-key",
              "value": "PASTE_CRON_SECRET_HERE"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "http-keepalive",
      "name": "POST /api/cron/keepalive",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0]
    }
  ],
  "connections": {
    "Every day 08:00": {
      "main": [
        [
          {
            "node": "POST /api/cron/keepalive",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
